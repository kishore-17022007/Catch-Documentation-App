rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /fishers/{fisherId} {
      // During development, allow any authenticated user to read/write their fisher data.
      // This prevents permission-denied errors from phone-number claim mismatches.
      allow read, write: if request.auth != null;

      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
